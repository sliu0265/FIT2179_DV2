{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Internet Usage, GDP per Capita and Population (2024)",
    "width": 500,
    "height": 350,
    "data": {"url": "../Data/Internet_usage.csv"},
    "mark": "circle",
    "transform": [
        {
          "lookup": "Country Code",
          "from": {
            "data":{"url":"../Data/GDP.csv"},
            "key": "Country Code",
            "fields": ["2024"]
          },
        "as": "GDP2024"
        },
        {
          "lookup": "Country Code",
          "from": {
            "data":{"url":"../Data/Population.csv"},
            "key": "Country Code",
            "fields": ["2024"]
          },
        "as": "Population2024"
        },
        {
          "filter": "datum['2024'] != null && datum['2024'] != '' && datum.GDP2024 != null && datum.GDP2024 != '' && datum.Population2024 != null && datum.Population2024 != ''"
        },
        {
          "filter": {
            "field": "Country Code",
            "oneOf": ["USA", "CHN", "IND", "AUS", "BRA", "ZAF", "FRA", "DEU", "JPN", "NGA", "IDN"]
          }
        },
        {
          "calculate": "toNumber(datum['2024'])",
          "as": "Usage2024Number"
        },
        {
          "filter": "datum.GDP2024 > 0 && datum.Usage2024Number >= 0 && datum.Population2024 > 0"
        },
        {
          "calculate": "'$' + format(datum.GDP2024, ',.2f')",
          "as": "GDP2024Label"
        },
        {
          "calculate": "format(datum.Usage2024Number, '.2f') + '%'",
          "as": "Usage2024Label"
        }
    ],
    "encoding": {
        "x": {
        "field": "GDP2024",
        "type": "quantitative",
        "title": "GDP per capita (current US$)",
        "scale": {"type": "log"},
        "axis": {"format": "$,.2f"}
        },
        "y": {
        "field": "Usage2024Number",
        "type": "quantitative",
        "title": "Internet Usage (%)"
        },
        "color": {
        "field": "Country Name",
        "type": "nominal",
        "title": "Country"
        },
        "size": {
        "field": "Population2024",
        "type": "quantitative",
        "title": "Population",
        "scale": {"range": [80, 2500]},
        "legend": null
        },
        "tooltip": [
        {
            "field": "Country Name",
            "type": "nominal",
            "title": "Country"
        },
        {
            "field": "GDP2024Label",
            "type": "nominal",
            "title": "GDP per capita"
        },
        {
            "field": "Usage2024Label",
            "type": "nominal",
            "title": "Internet Usage (%)"
        },
        {
            "field": "Population2024",
            "type": "nominal",
            "title": "Population"
        }
        ]
  }


}
