{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Top 10 Countries by ICT Service Exports as Share of GDP, 2024",
    "width": "container",
    "height": 300,
    "autosize": {
      "type": "fit",
      "contains": "padding"
    },
    "mark":"bar",
    "data":{"url": "Data/ICT_service_export.csv"},
    "transform": [
        {
            "lookup": "Country Code",
            "from": {
            "data": {"url": "Data/Internet_usage.csv"},
            "key": "Country Code",
            "fields": ["2024"]
            },
            "as": ["InternetUsageRaw"]
        },
        {
            "lookup": "Country Code",
            "from": {
            "data": {"url": "Data/IncomeGroup.csv"},
            "key": "Code",
            "fields": ["Income group"]
            },
            "as": ["IncomeGroup"]
        },
        {
            "calculate": "toNumber(datum['2024'])",
            "as": "ICTExportShareGDP"
        },
        {
            "calculate": "toNumber(datum.InternetUsageRaw)",
            "as": "InternetUsage2024"
        },
        {
            "filter": "datum.ICTExportShareGDP > 0 && isValid(datum.InternetUsage2024) && datum.IncomeGroup != null && datum.IncomeGroup != ''"
        },
        {
            "window": [{"op": "rank", "as": "ICTRank"}],
            "sort": [{"field": "ICTExportShareGDP", "order": "descending"}]
        },
        {
            "filter": "datum.ICTRank <= 10"
        }
    ],
    "encoding": {
        "x": {
            "field": "ICTExportShareGDP",
            "type": "quantitative",
            "title": "ICT Service Exports (% of GDP)",
            "axis": {
                "format": ".1f",
                "labelExpr": "datum.label + '%'"
            }
            },
        "y": {
            "field": "Country Name",
            "type": "nominal",
            "title": "Country",
            "sort": {"field": "ICTExportShareGDP", "order": "descending"}
            },
        "color": {
            "field": "InternetUsage2024",
            "type": "quantitative",
            "title": "Internet Usage (%)"
            },
        "tooltip": [
            {
                "field": "ICTRank",
                "type": "ordinal",
                "title": "Rank"
            },
            {
                "field": "Country Name",
                "type": "nominal",
                "title": "Country"
            },
            {
                "field": "ICTExportShareGDP",
                "type": "quantitative",
                "title": "ICT Service Exports (% of GDP)",
                "format": ".2f"
            },
            {
                "field": "InternetUsage2024",
                "type": "quantitative",
                "title": "Internet Usage (%)",
                "format": ".1f"
            },
            {
                "field": "IncomeGroup",
                "type": "nominal",
                "title": "Income Group"
            }
        ]
    }
}
