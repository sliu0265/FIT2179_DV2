{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Top 10 Countries by ICT Service Export Value, 2024",
    "width": 400,
    "height": 300,
    "mark":"bar",
    "data":{"url": "../Data/ICT_service_export_US$.csv"},
    "transform": [
        {
            "lookup": "Country Code",
            "from": {
            "data": {"url": "../Data/Internet_usage.csv"},
            "key": "Country Code",
            "fields": ["2024"]
            },
            "as": ["InternetUsageRaw"]
        },
        {
            "lookup": "Country Code",
            "from": {
            "data": {"url": "../Data/IncomeGroup.csv"},
            "key": "Code",
            "fields": ["Income group"]
            },
            "as": ["IncomeGroup"]
        },
        {
            "calculate": "toNumber(datum['2024'])",
            "as": "ICTExport2024"
        },
        {
            "calculate": "datum.ICTExport2024 / 1000000000",
            "as": "ICTExport2024Billion"
        },
        {
            "calculate": "toNumber(datum.InternetUsageRaw)",
            "as": "InternetUsage2024"
        },
        {
            "filter": "datum.ICTExport2024 > 0 && isValid(datum.InternetUsage2024) && datum.IncomeGroup != null && datum.IncomeGroup != ''"
        },
        {
            "window": [{"op": "rank", "as": "ICTRank"}],
            "sort": [{"field": "ICTExport2024", "order": "descending"}]
        },
        {
            "filter": "datum.ICTRank <= 10"
        }
    ],
    "encoding": {
        "x": {
            "field": "ICTExport2024Billion",
            "type": "quantitative",
            "title": "ICT Service Exports (US$ billions)",
            "axis": {
                "format": ".0f",
                "labelExpr": "'$' + datum.label + 'B'"
            }
            },
        "y": {
            "field": "Country Name",
            "type": "nominal",
            "title": "Country",
            "sort": {"field": "ICTExport2024", "order": "descending"}
            },
        "color": {
            "field": "InternetUsage2024",
            "type": "quantitative",
            "title": "Internet Usage (%)"
            },
        "tooltip": [
            {
                "field": "ICTRank",
                "type": "ordinal",
                "title": "Rank"
            },
            {
                "field": "Country Name",
                "type": "nominal",
                "title": "Country"
            },
            {
                "field": "ICTExport2024",
                "type": "quantitative",
                "title": "ICT Service Exports",
                "format": "$,.0f"
            },
            {
                "field": "ICTExport2024Billion",
                "type": "quantitative",
                "title": "ICT Service Exports (US$ billions)",
                "format": ".1f"
            },
            {
                "field": "InternetUsage2024",
                "type": "quantitative",
                "title": "Internet Usage (%)",
                "format": ".1f"
            },
            {
                "field": "IncomeGroup",
                "type": "nominal",
                "title": "Income Group"
            }
        ]
    }
}
